{
  "opencollection": "1.0.0",
  "info": {
    "name": "dLocal Cards API",
    "version": "2.1"
  },
  "request": {
    "auth": {
      "type": "apikey",
      "key": "Authorization",
      "value": "{{Authorization}}",
      "placement": "header"
    }
  },
  "items": [
    {
      "info": {
        "name": "Cards",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Create A Card",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.dlocal.com/secure_cards",
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Tokenize a card for use in future payments and recurring billing."
        },
        {
          "info": {
            "name": "Retrieve A Card",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.dlocal.com/secure_cards/:card_id",
            "params": [
              {
                "name": "card_id",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Retrieve a previously created card token."
        },
        {
          "info": {
            "name": "Delete A Card",
            "type": "http"
          },
          "http": {
            "method": "DELETE",
            "url": "https://api.dlocal.com/secure_cards/:card_id",
            "params": [
              {
                "name": "card_id",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Delete a previously created card token."
        }
      ]
    }
  ],
  "bundled": true
}