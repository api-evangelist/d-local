{
  "opencollection": "1.0.0",
  "info": {
    "name": "dLocal Refunds API",
    "version": "2.1"
  },
  "request": {
    "auth": {
      "type": "apikey",
      "key": "Authorization",
      "value": "{{Authorization}}",
      "placement": "header"
    }
  },
  "items": [
    {
      "info": {
        "name": "Refunds",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Make A Refund",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.dlocal.com/refunds",
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Initiate a refund for a previous payment. Omit `amount` to refund the full payment."
        },
        {
          "info": {
            "name": "Retrieve A Refund",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.dlocal.com/refunds/:refund_id",
            "params": [
              {
                "name": "refund_id",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Retrieve a refund by ID."
        },
        {
          "info": {
            "name": "Retrieve A Refund Status",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.dlocal.com/refunds/:refund_id/status",
            "params": [
              {
                "name": "refund_id",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Retrieve just the status of a refund."
        },
        {
          "info": {
            "name": "Retrieve Order Refund",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.dlocal.com/payments/:payment_id/refunds",
            "params": [
              {
                "name": "payment_id",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "List all refunds for a given payment."
        }
      ]
    }
  ],
  "bundled": true
}